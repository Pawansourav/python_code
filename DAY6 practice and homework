# Check if a string is Isogram or not
def Isogram(s):
    dic = {}
    for char in s:
        if char in dic:
            dic[char] = dic[char] + 1
        else:
            dic[char] =1
    for key,value in dic.items():
        if value > 1:
            return -1
        else:
            continue
    return 1
            
s = "machine"
final = Isogram(s)
print(final)

