
# Check if a string is Isogram or not
# TAKING o(**n) solution

def Isogram(s):
    for i in range(len(s)):
        res = s[i]
        
        for j in range(i+1,len(s)):
            if res == s[j]:
                return -1
            else:
                continue
    return 1
            
s = "machinie"
final = Isogram(s)
print(final)

